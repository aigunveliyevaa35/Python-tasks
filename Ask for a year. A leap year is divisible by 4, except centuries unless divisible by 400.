year = int(input("Enter the year: "))

if year % 4 == 0:
    if year % 100 == 0:
        if year % 400 == 0:
            print(f"{year} - Artıq ildir (Leap Year)")
        else:
            print(f"{year} - Artıq il deyil")
    else:
        print(f"{year} - Artıq ildir (Leap Year)")
else:
    print(f"{year} - Artıq il deyil")

