stored_user = "admin"
stored_pass = "1234"
attempts = 0  
while attempts < 3:
    user_input = input("User name: ")
    pass_input = input("Password: ")

    if user_input == stored_user and pass_input == stored_pass:
        print("Access Granted!")
        break;
    else:
        attempts += 1
        remaining = 3 - attempts
        if remaining > 0:
            print(f"Access Denied! Number of attempts remaining: {remaining}")
        else:
            print("account is blocked! You tried 3 times.")

